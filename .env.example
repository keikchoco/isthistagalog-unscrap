# ============================================================================
# DATABASE
# ============================================================================

# MongoDB connection string
# Required for user, scan, and pin data persistence
# Format: mongodb+srv://username:password@cluster.mongodb.net/?appName=name
# or mongodb://localhost:27017/ for local development
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=appname

# Optional: Database name (defaults to 'unscrap' or first database in URI)
# MONGODB_DB=unscrap

# ============================================================================
# AUTHENTICATION (Better Auth)
# ============================================================================

# Secret key for Better Auth session signing (REQUIRED)
# Must be at least 32 characters long. Generate with: openssl rand -hex 16
# Keep this secure and never commit the actual value
BETTER_AUTH_SECRET=your_32plus_character_secret_key_here

# Base URL for Better Auth endpoints (REQUIRED)
# Development: http://localhost:3000
# Production: https://yourdomain.com
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# ============================================================================
# AI & ANALYSIS
# ============================================================================

# Google Gemini API key for waste image analysis (REQUIRED)
# Get from: https://ai.google.dev/
# Used for classifying waste items and generating sustainability suggestions
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-flash-latest

# ============================================================================
# STORAGE
# ============================================================================

# Vercel Blob read/write token for image storage (REQUIRED for production)
# Get from: https://vercel.com/docs/storage/vercel-blob
# Allows uploading and serving scan images with public URLs
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxx_your_token_here

# ============================================================================
# ENVIRONMENT & DEBUGGING
# ============================================================================

# Node environment (development, production, test)
# Typically set by deployment platform; only set if needed locally
# NODE_ENV=development

# Optional: Enable verbose logging for debugging
# DEBUG=unscrap:*
